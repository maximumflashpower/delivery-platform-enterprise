# ===================================
# DELIVERY PLATFORM ENTERPRISE ENV
# ===================================

# --- Application ---
NODE_ENV=development
PORT=3000
API_PREFIX=api

# --- Database (PostgreSQL) ---
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=lumo_secure_pass_2026
DB_DATABASE=bankchat_core
DB_SYNCHRONIZE=true
DB_LOGGING=true

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- JWT ---
JWT_SECRET=cambia_esto_por_un_secret_de_32_caracteres_minimos_ahora
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=cambia_esto_por_refresh_secret_32_caracteres
JWT_REFRESH_EXPIRES_IN=7d

# --- Twilio (OTP) ---
TWILIO_ACCOUNT_SID=AC_placeholder
TWILIO_AUTH_TOKEN=token_placeholder
TWILIO_PHONE_NUMBER=+1234567890

# --- Stripe (Payments) ---
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder

# --- AWS S3 (Storage) ---
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=placeholder
AWS_SECRET_ACCESS_KEY=placeholder
AWS_S3_BUCKET=placeholder

# --- Logging ---
LOG_LEVEL=debug
LOG_FORMAT=combined

# --- Throttle ---
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# --- CORS ---
CORS_ORIGIN=http://localhost:3001

# --- Swagger ---
SWAGGER_ENABLED=true
SWAGGER_TITLE=Delivery Platform API
SWAGGER_VERSION=v1.0.0
