# Application
APP_PORT=3000
API_PREFIX=api
NODE_ENV=development

# Database (Development: SQLite / Production: PostgreSQL)
DB_TYPE=sqlite
DB_PATH=./dev.db
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=delivery_platform

# Auth - JWT (CHANGE THESE IN PRODUCTION!)
JWT_SECRET=your-super-secret-key-min-32-characters-change-this-now
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-refresh-token-secret-min-32-characters-change-this-now
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:3001

# Rate Limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_LIMIT=100

# Swagger
SWAGGER_ENABLED=true
