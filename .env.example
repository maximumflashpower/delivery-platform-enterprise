# Application
APP_PORT=3000
API_PREFIX=api
NODE_ENV=development

# Database
DB_TYPE=sqlite
DB_PATH=./dev.db
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=delivery_platform

# Auth
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=1d

# CORS
CORS_ORIGIN=*

# Rate Limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_LIMIT=100
