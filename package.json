{
  "name": "delivery-platform-enterprise",
  "version": "1.0.0",
  "description": "Delivery Platform Enterprise — Multi-Domain Mobility & Logistics System",
  "author": "ubuntu-77",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "typeorm": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js",
    "db:migrate": "npm run typeorm -- migration:run -d src/data-source.ts",
    "db:migrate:revert": "npm run typeorm -- migration:revert -d src/data-source.ts",
    "db:migration:generate": "npm run typeorm -- migration:generate -d src/data-source.ts",
    "db:migration:create": "npm run typeorm -- migration:create",
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "db:migrate": "npx typeorm-ts-node-commonjs migration:run -d src/config/database.datasource.ts",
    "db:migrate:create": "npx typeorm-ts-node-commonjs migration:generate",
    "db:revert": "npx typeorm-ts-node-commonjs migration:revert -d src/config/database.datasource.ts",
    "db:drop": "npx typeorm-ts-node-commonjs schema:drop -d src/config/database.datasource.ts",
    "db:sync": "npx typeorm-ts-node-commonjs schema:sync -d src/config/database.datasource.ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.3.0",
    "@nestjs/core": "^11.1.28",
    "@nestjs/platform-express": "^11.1.28",
    "@nestjs/platform-socket.io": "^11.1.28",
    "@nestjs/websockets": "^11.1.28",
    "@nestjs/config": "^4.0.4",
    "@nestjs/typeorm": "^11.0.3",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/swagger": "^11.4.5",
    "@nestjs/axios": "^3.0.1",
    "@nestjs/microservices": "^11.1.28",
    "typeorm": "^1.1.0",
    "pg": "^8.11.3",
    "redis": "^4.6.12",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "bcrypt": "^5.1.1",
    "class-validator": "^0.14.0",
    "class-transformer": "^0.5.1",
    "helmet": "^7.1.0",
    "compression": "^1.7.4",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^4.7.1",
    "prom-client": "^15.1.0",
    "dotenv": "^16.3.1",
    "joi": "^17.11.0",
    "nanoid": "^3.3.7",
    "sharp": "^0.33.1",
    "multer": "^2.2.0",
    "uuid": "^14.0.1",
    "dayjs": "^1.11.10",
    "geojson": "^0.5.0",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.24",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.28",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.6",
    "@types/passport-jwt": "^4.0.0",
    "@types/bcrypt": "^5.0.2",
    "@types/jest": "^30.0.0",
    "@types/multer": "^1.4.11",
    "@types/uuid": "^9.0.7",
    "@types/compression": "^1.7.5",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.2",
    "jest": "^30.4.2",
    "prettier": "^3.1.1",
    "source-map-support": "^0.5.21",
    "ts-jest": "^29.1.1",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.3"
  },
  "jest": {
    "moduleFileExtensions": ["js", "json", "ts"],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": ["**/*.(t|j)s"],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
