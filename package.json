  "scripts": {
    "typeorm": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js",
    "db:migrate": "ts-node -P tsconfig.json -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:run -d src/data-source.ts",
    "db:migrate:revert": "ts-node -P tsconfig.json -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:revert -d src/data-source.ts",
    "db:migration:generate": "ts-node -P tsconfig.json -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:generate -d src/data-source.ts",
    "db:migration:create": "ts-node -P tsconfig.json -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:create",
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config test/e2e/jest-e2e.json",
    "db:migrate:create": "npx typeorm-ts-node-commonjs migration:generate",
    "db:revert": "npx typeorm-ts-node-commonjs migration:revert -d src/config/database.datasource.ts",
    "db:drop": "ts-node -P tsconfig.json -r tsconfig-paths/register ./node_modules/typeorm/cli.js schema:drop -d src/data-source.ts",
    "db:sync": "ts-node -P tsconfig.json -r tsconfig-paths/register ./node_modules/typeorm/cli.js schema:sync -d src/data-source.ts",
    "seed": "ts-node infrastructure/database/seeds/run-seed.ts",
    "db:migrate:show": "ts-node -P tsconfig.json -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:show -d src/data-source.ts"
  },
